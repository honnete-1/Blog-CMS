---
// Hero Component
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <h1 class="fade-in">Embrace Your Holistic Journey</h1>
    <p class="fade-in" style="animation-delay: 0.1s;">
      The Curious Explorer is your guide to growing spiritually, physically, academically, mentally, and financially. Rooted in faith.
    </p>
    <a href="#pillars" class="cta-button fade-in" style="animation-delay: 0.2s;">Start Your Journey</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 0;
    text-align: center;
    color: white;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-forest) 0%, #1a3c16 100%);
    z-index: -1;
  }
  
  /* Adding a subtle texture or pattern over the gradient could enhance aesthetics. 
     For now, this profound green gradient looks premium and grounded. */

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100px;
    background: linear-gradient(to top, var(--color-background), transparent);
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    color: var(--color-gold);
    font-size: 4rem;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  .hero p {
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    line-height: 1.8;
    color: #e8e8e8;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: var(--color-gold);
    color: var(--color-forest);
    font-weight: 600;
    font-size: 1.1rem;
    border-radius: 50px;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);
    transition: all var(--transition-speed) ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.6);
    background-color: #f7d25e;
    color: var(--color-forest);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 0;
    }
    .hero h1 {
      font-size: 2.5rem;
    }
    .hero p {
      font-size: 1.1rem;
    }
  }
</style>
