      props: { title: "Understanding Sins to Abhor", date: "August 25, 2026", content: "This is an introductory guide to Sins to Abhor. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'spiritual-growth', category: 'gods-love', post: 'introduction-guide' },
      props: { title: "Understanding God's Love", date: "August 25, 2026", content: "This is an introductory guide to God's Love. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'physical-stewardship', category: 'nutrition', post: 'introduction-guide' },
      props: { title: "Understanding Nutrition", date: "August 25, 2026", content: "This is an introductory guide to Nutrition. Let this serve as the foundation for your ongoing journey here." }
