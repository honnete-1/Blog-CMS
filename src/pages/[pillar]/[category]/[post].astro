      }
    },
    { 
      params: { pillar: 'mental-growth', category: 'mindfulness', post: 'finding-stillness' },
      props: { 
        title: "Finding Stillness in a Noisy World",
        date: "August 15, 2026",
        content: "The world is constantly competing for our attention. Finding stillness requires intentional isolation and disconnecting from the digital noise. It's in the quiet spaces that we hear ourselves and God the clearest."
      }
    },
    {
