      params: { pillar: 'physical-stewardship', category: 'fitness', post: 'introduction-guide' },
      props: { title: "Understanding Fitness", date: "August 25, 2026", content: "This is an introductory guide to Fitness. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'physical-stewardship', category: 'rest', post: 'introduction-guide' },
      props: { title: "Understanding Rest", date: "August 25, 2026", content: "This is an introductory guide to Rest. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'academic-growth', category: 'learning', post: 'introduction-guide' },
      props: { title: "Understanding Continuous Learning", date: "August 25, 2026", content: "This is an introductory guide to Continuous Learning. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'academic-growth', category: 'focus', post: 'introduction-guide' },
      props: { title: "Understanding Focus & Discipline", date: "August 25, 2026", content: "This is an introductory guide to Focus & Discipline. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'mental-growth', category: 'mindfulness', post: 'introduction-guide' },
      props: { title: "Understanding Mindfulness", date: "August 25, 2026", content: "This is an introductory guide to Mindfulness. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'mental-growth', category: 'resilience', post: 'introduction-guide' },
      props: { title: "Understanding Resilience", date: "August 25, 2026", content: "This is an introductory guide to Resilience. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'mental-growth', category: 'relationships', post: 'introduction-guide' },
      props: { title: "Understanding Relationships", date: "August 25, 2026", content: "This is an introductory guide to Relationships. Let this serve as the foundation for your ongoing journey here." }
    },
    {
      params: { pillar: 'financial-growth', category: 'stewardship', post: 'introduction-guide' },
      props: { title: "Understanding Biblical Stewardship", date: "August 25, 2026", content: "This is an introductory guide to Biblical Stewardship. Let this serve as the foundation for your ongoing journey here." }
