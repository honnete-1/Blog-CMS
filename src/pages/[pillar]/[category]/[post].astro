const { pillar, category } = Astro.params;
const { title, date, content } = Astro.props;
---

<BaseLayout title={title}>
  <article class="post-detail container">
    <div class="post-main fade-in">
      <header class="post-header">
        <div class="post-meta">
          <a href={`/${pillar}/${category}`} class="category-link">{category.replace('-', ' ').toUpperCase()}</a>
          <span class="dot">&bull;</span>
          <span class="date">{date}</span>
        </div>
        <h1 class="post-title">{title}</h1>
      </header>
      
      <div class="post-body">
        <p class="dropcap">{content}</p>
        
        <p>As we journey through this life, these principles hold true regardless of circumstance. The key is consistency and returning to the foundational truths when we drift away.</p>
        
        <blockquote>
          "Excellence is not an act, but a habit."
        </blockquote>
        
        <p>Let us endeavor to make growth a continuous pursuit rather than a destination. By taking small, faithful steps every day, we build a life that honors God and serves others.</p>
      </div>
    </div>
    
    <div class="post-sidebar fade-in" style="animation-delay: 0.2s;">
      <div class="sticky-sidebar">
        <Sidebar />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-detail {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    padding: 5rem 1rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    padding-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .category-link {
    color: var(--color-secondary);
  }
  
  .category-link:hover {
    text-decoration: underline;
  }

  .post-title {
    font-size: 3.5rem;
    color: var(--color-primary);
    line-height: 1.1;
  }

  .post-body {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-text-main);
  }
  
  .post-body p {
    margin-bottom: 1.5rem;
  }

  .dropcap::first-letter {
    font-family: var(--font-heading);
    font-size: 4.5rem;
    float: left;
    margin-right: 0.5rem;
    line-height: 0.8;
    color: var(--color-primary);
    margin-top: 0.5rem;
  }

  .post-body blockquote {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-style: italic;
    color: var(--color-primary);
    border-left: 4px solid var(--color-secondary);
    padding-left: 2rem;
    margin: 3rem 0;
    line-height: 1.4;
  }

  .sticky-sidebar {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 900px) {
    .post-detail {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .post-title {
      font-size: 2.5rem;
    }
    
    .sticky-sidebar {
      position: static;
    }
  }
</style>
